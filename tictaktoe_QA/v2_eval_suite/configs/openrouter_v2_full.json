{
  "env_file": "tictaktoe_QA/.env",
  "api_base": "https://openrouter.ai/api/v1",
  "dataset_source": "local_jsonl",
  "dataset_dir": "tictaktoe_QA/synth_dataset/outputs/v2",
  "split": "test",
  "task_types": [
    "best_move",
    "has_winning_move",
    "available_moves_count",
    "turn_player",
    "winner",
    "game_over",
    "available_moves_list"
  ],
  "max_samples_per_task": 0,
  "sample_strategy": "stratified",
  "stratify_tasks": [
    "turn_player",
    "available_moves_count"
  ],
  "seed": 42,
  "temperature": 0.0,
  "top_p": 1.0,
  "max_tokens": 1024,
  "timeout": 90.0,
  "retry_429_max_retries": 2,
  "retry_429_backoff_s": 1.0,
  "retry_429_max_backoff_s": 8.0,
  "best_move_optimal_reward": 0.7,
  "models": [
    {
      "label": "claude_frontier_control",
      "model_id": "anthropic/claude-3.7-sonnet"
    },
    {
      "label": "claude_frontier_reasoning",
      "model_id": "anthropic/claude-3.7-sonnet",
      "request_overrides": {
        "reasoning": {
          "effort": "medium"
        }
      }
    },
    {
      "label": "chatgpt_frontier_control",
      "model_id": "openai/gpt-5.1"
    },
    {
      "label": "chatgpt_frontier_reasoning",
      "model_id": "openai/gpt-5.1",
      "request_overrides": {
        "reasoning": {
          "effort": "medium"
        }
      }
    },
    {
      "label": "qwen_vl_frontier_control",
      "model_id": "qwen/qwen-2.5-vl-7b-instruct"
    },
    {
      "label": "qwen_vl_frontier_reasoning",
      "model_id": "qwen/qwen-2.5-vl-7b-instruct",
      "request_overrides": {
        "reasoning": {
          "effort": "medium"
        }
      }
    }
  ]
}
