{
  "env_file": ".env",
  "dataset_source": "hf_hub",
  "hf_dataset_repo_id": "maxs-m87/tictactoe-qa-v2",
  "hf_dataset_revision": "main",
  "hf_cache_dir": "",
  "dataset_dir": "",
  "train_split": "train",
  "val_split": "val",
  "final_eval_splits": [
    "val",
    "test",
    "benchmark_top50_canonical",
    "benchmark_top50_paraphrase"
  ],
  "finetune_id": "",
  "finetune_name": "ttt_query_bm_e3_scaffold_multitask",
  "rank": 16,
  "num_steps": 240,
  "resume_step": 0,
  "batch_size": 16,
  "group_size": 6,
  "lr": 0.0003,
  "temperature": 1.0,
  "top_p": 0.9,
  "eval_temperature": 0.0,
  "eval_top_p": 1.0,
  "max_tokens": 128,
  "max_tokens_by_task": {
    "best_move": 64,
    "has_winning_move": 32,
    "is_game_over": 32,
    "turn_player": 32
  },
  "reasoning": false,
  "eval_reasoning": false,
  "task_sampling_weights": {
    "best_move": 0.75,
    "has_winning_move": 0.1,
    "is_game_over": 0.1,
    "turn_player": 0.05,
    "available_moves_count": 0.0,
    "available_moves_list": 0.0,
    "winner": 0.0
  },
  "max_workers": 4,
  "rollout_retries": 2,
  "rollout_retry_backoff_s": 1.0,
  "eval_every": 10,
  "save_every": 10,
  "save_on_eval": true,
  "eval_batch_size": 32,
  "eval_max_samples": 1000,
  "checkpoint_avg_splits": [
    "val",
    "test"
  ],
  "checkpoint_avg_metric": "eval_best_move_canonical_accuracy",
  "checkpoint_ranking_output": "outputs/checkpoint_ranking_exp_e3_scaffold_multitask.json",
  "seed": 42,
  "best_metric": "eval_best_move_canonical_accuracy",
  "best_move_optimal_reward": 0.7,
  "best_move_reward_mode": "binary",
  "best_move_wrong_rank_scale": 0.0,
  "best_move_center_not_optimal_ratio": 0.85,
  "intra_task_sampling_json": {
    "best_move": "uniform_canonical_move",
    "turn_player": "balanced_player"
  },
  "center_bias_gate_enabled": true,
  "center_bias_gate_threshold": 0.5,
  "center_bias_gate_after_evals": 2,
  "center_bias_gate_min_best_move_samples": 80,
  "auto_benchmark_config": "configs/benchmark_best_move_strict.json",
  "wandb_log_profile": "lean",
  "no_progress": false,
  "wandb_project": "moondream-ttt-query-rl",
  "wandb_run_name": "ttt_query_bm_e3_scaffold_multitask"
}
