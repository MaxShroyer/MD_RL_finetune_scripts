{
  "env_file": ".env",
  "api_base": "https://openrouter.ai/api/v1",
  "dataset_name": "maxs-m87/pandid_dataset_v2",
  "dataset_path": "",
  "split": "post_val",
  "max_samples": 120,
  "skills": [
    "detect",
    "point"
  ],
  "point_prompt_style": "detect_phrase",
  "neg_prompts_per_empty": 2,
  "neg_prompts_per_nonempty": 1,
  "temperature": 0.0,
  "top_p": 1.0,
  "max_tokens": 512,
  "max_objects": 50,
  "timeout": 90.0,
  "retry_429_max_retries": 2,
  "retry_429_backoff_s": 1.0,
  "retry_429_max_backoff_s": 8.0,
  "min_request_interval_s": 0.0,
  "iou_threshold": 0.5,
  "seed": 42,
  "progress_every": 50,
  "viz_samples": 0,
  "viz_dir": "outputs/benchmark_viz_openrouter_pid",
  "models": [
    {
      "label": "claude_frontier",
      "model_id": "anthropic/claude-3.7-sonnet"
    },
    {
      "label": "chatgpt_frontier",
      "model_id": "openai/gpt-5.1"
    },
    {
      "label": "qwen_vl_frontier",
      "model_id": "qwen/qwen-2.5-vl-7b-instruct"
    }
  ]
}
